{
  "name": "better-auth-razorpay-plugin",
  "version": "0.1.0",
  "description": "Better Auth plugin for Razorpay payments, subscriptions, checkout, webhooks, and React Query helpers.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "https://github.com/kaustubhkagrawal/better-auth-razorpay-plugin#readme",
  "bugs": {
    "url": "https://github.com/kaustubhkagrawal/better-auth-razorpay-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaustubhkagrawal/better-auth-razorpay-plugin.git"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "razorpay",
    "payments",
    "payment-gateway",
    "checkout",
    "subscriptions",
    "billing",
    "webhooks",
    "authentication",
    "auth",
    "react-query",
    "tanstack-query",
    "saas",
    "india-payments",
    "typescript"
  ],
  "peerDependencies": {
    "@better-auth/core": "^1.6.9",
    "@tanstack/react-query": "^5.0.0",
    "better-auth": "^1.6.9",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "razorpay": "^2.9.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/core": "^1.6.9",
    "@tanstack/react-query": "^5.100.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "4.1.5",
    "better-auth": "^1.6.9",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0"
}
