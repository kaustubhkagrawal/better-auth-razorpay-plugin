{
  "name": "better-auth-razorpay-plugin",
  "version": "0.1.0",
  "description": "Razorpay plugin for Better Auth.",
  "type": "module",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zoratrox/better-auth-razorpay-plugin.git"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "better-auth",
    "better-auth-plugin",
    "razorpay",
    "payments",
    "typescript"
  ],
  "peerDependencies": {
    "@better-auth/core": "^1.6.9",
    "@tanstack/react-query": "^5.0.0",
    "better-auth": "^1.6.9",
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "razorpay": "^2.9.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/core": "^1.6.9",
    "@tanstack/react-query": "^5.100.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "better-auth": "^1.6.9",
    "react": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  }
}
